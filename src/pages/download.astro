---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// 部署后替换为 GitHub Release 或对象存储链接
const apkUrl = 'https://github.com/JamesJen627/QuestSphere/releases';
---

<BaseLayout title="下载 — 题域 QuestSphere" description="下载题域 Android App">
  <Header slot="header" />

  <section class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-3xl font-bold text-slate-900">下载题域 App</h1>
    <p class="mt-4 text-lg text-slate-600">
      题域目前为 Android 应用。请从 GitHub Release 获取最新 APK，或在应用商店上架后从此页更新链接。
    </p>

    <a
      href={apkUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-flex rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700"
    >
      前往 GitHub Release
    </a>

    <div class="mt-10 rounded-xl border border-slate-200 bg-white p-6 text-sm text-slate-600">
      <p class="font-medium text-slate-800">安装提示</p>
      <ul class="mt-3 list-disc space-y-2 pl-5">
        <li>内测期可能需要允许「安装未知来源应用」。</li>
        <li>导入 Excel 与订阅公开包需在 App 内完成。</li>
        <li>公开包分享页：<code class="rounded bg-slate-100 px-1.5 py-0.5">/pack/[packId]</code></li>
      </ul>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
