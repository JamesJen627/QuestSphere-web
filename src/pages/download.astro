---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const isBeta = true;
---

<BaseLayout
  title="下载 — 题域 QuestSphere"
  description="题域 Android App 内测筹备中。公开包预览已开放，完整刷题与导入功能将在 App 内测开放后提供。"
>
  <Header slot="header" />

  <section class="mx-auto max-w-3xl px-4 py-16">
    <p class="text-sm font-medium text-amber-700">内测筹备中</p>
    <h1 class="mt-3 text-3xl font-bold text-slate-900">题域 Android App</h1>
    <p class="mt-4 text-lg leading-8 text-slate-600">
      题域目前为 Android 应用，正在内测准备阶段，<strong>暂未开放公开下载</strong>。
      完整功能（Excel 导入、刷题、订阅公开包等）需在 App 内完成。
    </p>

    {
      isBeta && (
        <div class="mt-8 rounded-xl border border-amber-200 bg-amber-50 p-6 text-sm text-amber-900">
          <p class="font-semibold">为什么还不能下载？</p>
          <p class="mt-2 leading-7">
            题域仍在本地开发与内测验证中，尚未公开发布安装包。正式开放下载后，此页将更新为最新版本说明与获取方式。
          </p>
        </div>
      )
    }

    <div class="mt-10 rounded-xl border border-slate-200 bg-white p-6">
      <p class="font-semibold text-slate-800">现在可以做什么</p>
      <ul class="mt-4 space-y-4 text-sm text-slate-600">
        <li class="flex gap-3">
          <span class="font-medium text-blue-600">预览</span>
          <span>
            浏览公开包分享页，查看题库标题、描述与前 3 题预览。
            <a href="/packs" class="ml-1 font-medium text-blue-600 hover:text-blue-700">
              浏览公开包 →
            </a>
          </span>
        </li>
        <li class="flex gap-3">
          <span class="font-medium text-blue-600">了解</span>
          <span>
            阅读导入说明与 FAQ，提前了解 Excel 导入与全链路产品生态。
            <a href="/docs" class="ml-1 font-medium text-blue-600 hover:text-blue-700">
              查看文档 →
            </a>
          </span>
        </li>
        <li class="flex gap-3">
          <span class="font-medium text-slate-400">订阅</span>
          <span class="text-slate-500">在 App 内测开放后，可从公开包预览页跳转至此页获取安装包，并在 App 中订阅导入。</span>
        </li>
      </ul>
    </div>

    <div class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-6 text-sm text-slate-600">
      <p class="font-medium text-slate-800">开放下载后将提供</p>
      <ul class="mt-3 list-disc space-y-2 pl-5">
        <li>Android APK 安装包与版本更新说明</li>
        <li>最低系统版本与安装指引</li>
        <li>应用商店链接（若已上架）</li>
      </ul>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
