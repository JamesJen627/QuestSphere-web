---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const { packId } = Astro.params;

if (!packId) {
  return Astro.redirect('/');
}
---

<BaseLayout title="公开包预览 — 题域" description="在题域 App 中订阅此公开包">
  <Header slot="header" />

  <section class="mx-auto max-w-3xl px-4 py-16" id="pack-preview" data-pack-id={packId}>
    <p class="text-sm text-slate-500">加载中…</p>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  import { stripMarkdownForPreview } from '../../lib/preview';
  import type { PublicPackPayload, PublicPackRow } from '../../types/public-pack';

  const root = document.getElementById('pack-preview');
  const packId = root?.dataset.packId;

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const anonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  function renderError(message: string) {
    if (!root) return;
    root.innerHTML = `
      <div class="rounded-xl border border-red-200 bg-red-50 p-6 text-red-700">
        <p class="font-semibold">无法加载公开包</p>
        <p class="mt-2 text-sm">${message}</p>
      </div>
    `;
  }

  function renderNotFound() {
    if (!root) return;
    root.innerHTML = `
      <div class="rounded-xl border border-slate-200 bg-white p-6">
        <p class="font-semibold text-slate-800">未找到公开包</p>
        <p class="mt-2 text-sm text-slate-600">packId: ${packId}</p>
      </div>
    `;
  }

  function renderPack(pack: PublicPackRow) {
    if (!root) return;

    const payload = pack.payload_json as PublicPackPayload | undefined;
    const previewQuestions = payload?.questions?.slice(0, 3) ?? [];
    const tags = (pack.tags ?? [])
      .map((tag) => `<span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700">${tag}</span>`)
      .join('');

    const questions = previewQuestions
      .map(
        (q, index) => `
          <article class="rounded-xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-medium uppercase text-slate-400">第 ${index + 1} 题</p>
            <p class="mt-2 whitespace-pre-wrap text-slate-800">${stripMarkdownForPreview(q.question)}</p>
          </article>
        `,
      )
      .join('');

    document.title = `${pack.title} — 题域预览`;

    root.innerHTML = `
      <div class="space-y-3">
        <p class="text-sm font-medium text-blue-600">公开包预览</p>
        <h1 class="text-3xl font-bold text-slate-900">${pack.title}</h1>
        ${pack.description ? `<p class="text-lg text-slate-600">${pack.description}</p>` : ''}
        <div class="flex flex-wrap gap-3 text-sm text-slate-500">
          ${pack.author_nickname ? `<span>作者：${pack.author_nickname}</span>` : ''}
          ${pack.question_count != null ? `<span>${pack.question_count} 题</span>` : ''}
          ${pack.version != null ? `<span>版本 v${pack.version}</span>` : ''}
        </div>
        ${tags ? `<div class="flex flex-wrap gap-2">${tags}</div>` : ''}
      </div>
      ${
        questions
          ? `<div class="mt-10 space-y-4">
              <h2 class="text-lg font-semibold text-slate-800">题目预览（前 3 题）</h2>
              ${questions}
            </div>`
          : ''
      }
      <a href="/download" class="mt-10 inline-flex rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700">
        在题域 App 中订阅
      </a>
    `;
  }

  async function loadPack() {
    if (!root || !packId) return;

    if (!supabaseUrl || !anonKey) {
      renderError('请配置 PUBLIC_SUPABASE_URL 与 PUBLIC_SUPABASE_ANON_KEY');
      return;
    }

    try {
      const url = new URL(`${supabaseUrl}/rest/v1/public_packs`);
      url.searchParams.set('select', '*');
      url.searchParams.set('pack_id', `eq.${packId}`);
      url.searchParams.set('limit', '1');

      const res = await fetch(url, {
        headers: {
          apikey: anonKey,
          Authorization: `Bearer ${anonKey}`,
        },
      });

      if (!res.ok) {
        renderError(`Supabase 请求失败：${res.status}`);
        return;
      }

      const rows = (await res.json()) as PublicPackRow[];
      const pack = rows[0];
      if (!pack) {
        renderNotFound();
        return;
      }

      renderPack(pack);
    } catch {
      renderError('网络错误，请稍后重试');
    }
  }

  loadPack();
</script>
