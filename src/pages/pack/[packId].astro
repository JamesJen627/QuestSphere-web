---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EmptyState from '../../components/EmptyState.astro';
import { fetchPublicPack } from '../../lib/supabase';
import { buildPackShareMeta } from '../../lib/pack-meta';
import { formatDateZh } from '../../lib/format';
import { stripMarkdownForPreview } from '../../lib/preview';
import { parsePayloadJson } from '../../lib/payload';
import type { PublicPackPayload } from '../../types/public-pack';

const { packId } = Astro.params;

if (!packId) {
  return Astro.redirect('/');
}

let pack = null;
let errorMessage: string | null = null;
let isConfigError = false;

try {
  pack = await fetchPublicPack(packId);
} catch (error) {
  errorMessage = error instanceof Error ? error.message : '加载失败';
  isConfigError = errorMessage.includes('环境变量');
}

if (!pack && !errorMessage) {
  Astro.response.status = 404;
}

const payload = parsePayloadJson(pack?.payload_json);
const previewQuestions = payload?.questions?.slice(0, 3) ?? [];
const updatedLabel = formatDateZh(pack?.updated_at);
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.url.origin;
const shareUrl = new URL(Astro.url.pathname, siteUrl).href;

const shareMeta = pack ? buildPackShareMeta(pack) : null;

const pageTitle = shareMeta?.title ?? (errorMessage ? '加载失败 — 题域' : '未找到公开包 — 题域');

const pageDescription =
  shareMeta?.description ??
  (errorMessage ? errorMessage : `未找到 packId 为 ${packId} 的公开包，可在发现页浏览其他题库。`);
---

<BaseLayout title={pageTitle} description={pageDescription} ogType="article">
  <Header slot="header" />

  <section class="mx-auto max-w-3xl px-4 py-16">
    {
      errorMessage ? (
        <EmptyState
          title={isConfigError ? '服务配置不完整' : '无法加载公开包'}
          description={
            isConfigError
              ? '站点尚未配置 Supabase 连接，公开包预览暂不可用。若你是站点维护者，请配置 PUBLIC_SUPABASE_URL 与 PUBLIC_SUPABASE_ANON_KEY。'
              : errorMessage
          }
        />
      ) : !pack ? (
        <EmptyState
          title="未找到此公开包"
          description="该分享链接可能已失效，或公开包已被下架。你可以浏览其他公开包，或了解题域 App。"
          packId={packId}
        />
      ) : (
        <>
          <div class="space-y-3">
            <p class="text-sm font-medium text-blue-600">公开包预览</p>
            <h1 class="text-3xl font-bold text-slate-900">{pack.title}</h1>
            {pack.description && <p class="text-lg text-slate-600">{pack.description}</p>}
            <div class="flex flex-wrap gap-3 text-sm text-slate-500">
              {pack.author_nickname && <span>作者：{pack.author_nickname}</span>}
              {pack.question_count != null && <span>{pack.question_count} 题</span>}
              {pack.version != null && <span>版本 v{pack.version}</span>}
              {updatedLabel && <span>更新于 {updatedLabel}</span>}
            </div>
            {pack.tags && pack.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {pack.tags.map((tag) => (
                  <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>

          <p class="mt-6 rounded-lg border border-blue-100 bg-blue-50 px-4 py-3 text-sm text-blue-800">
            本站可预览题库信息与前几道题。完整订阅与刷题需在题域 App 内完成（内测筹备中）。
          </p>

          {previewQuestions.length > 0 ? (
            <div class="mt-10 space-y-4">
              <h2 class="text-lg font-semibold text-slate-800">题目预览（前 3 题）</h2>
              {previewQuestions.map((question, index) => (
                <article class="rounded-xl border border-slate-200 bg-white p-5">
                  <p class="text-xs font-medium uppercase text-slate-400">第 {index + 1} 题</p>
                  <p class="mt-2 whitespace-pre-wrap text-slate-800">
                    {stripMarkdownForPreview(question.question)}
                  </p>
                </article>
              ))}
            </div>
          ) : (
            <p class="mt-10 text-sm text-slate-500">暂无题目预览内容。</p>
          )}

          <div class="mt-10 flex flex-wrap gap-3">
            <a
              href="/download"
              class="inline-flex rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700"
            >
              了解 App · 内测筹备中
            </a>
            <button
              type="button"
              id="copy-share-link"
              data-url={shareUrl}
              class="inline-flex rounded-lg border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-blue-300 hover:text-blue-600"
            >
              复制分享链接
            </button>
          </div>
          <p id="copy-feedback" class="mt-3 hidden text-sm text-green-600">链接已复制</p>
        </>
      )
    }
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const button = document.getElementById('copy-share-link');
  const feedback = document.getElementById('copy-feedback');

  button?.addEventListener('click', async () => {
    const url = button.getAttribute('data-url');
    if (!url) return;

    try {
      await navigator.clipboard.writeText(url);
      feedback?.classList.remove('hidden');
      window.setTimeout(() => feedback?.classList.add('hidden'), 2000);
    } catch {
      window.prompt('复制以下链接：', url);
    }
  });
</script>
