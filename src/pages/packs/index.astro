---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EmptyState from '../../components/EmptyState.astro';
import { listPublicPacks } from '../../lib/supabase';
import { formatDateZh } from '../../lib/format';

const query = Astro.url.searchParams.get('q')?.trim() ?? '';

let packs = [];
let errorMessage: string | null = null;
let isConfigError = false;

try {
  packs = await listPublicPacks({ limit: 50, query: query || undefined });
} catch (error) {
  errorMessage = error instanceof Error ? error.message : '加载失败';
  isConfigError = errorMessage.includes('环境变量');
}
---

<BaseLayout
  title={query ? `搜索「${query}」— 发现公开包` : '发现公开包 — 题域 QuestSphere'}
  description="浏览题域发现页中的公开题库，预览题目并在 App 中订阅导入。"
>
  <Header slot="header" />

  <section class="mx-auto max-w-5xl px-4 py-16">
    <div class="max-w-2xl">
      <p class="text-sm font-medium text-blue-600">发现题库</p>
      <h1 class="mt-2 text-3xl font-bold text-slate-900">公开包目录</h1>
      <p class="mt-4 text-lg text-slate-600">
        浏览已上架的公开题库。点击可预览前 3 题；完整刷题与订阅导入请在题域 App 内完成。
      </p>
    </div>

    <form method="get" action="/packs" class="mt-8 flex max-w-xl gap-3">
      <label for="pack-search" class="sr-only">搜索公开包</label>
      <input
        id="pack-search"
        type="search"
        name="q"
        value={query}
        placeholder="搜索标题、描述或作者…"
        class="flex-1 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm text-slate-900 shadow-sm outline-none transition focus:border-blue-400 focus:ring-2 focus:ring-blue-100"
      />
      <button
        type="submit"
        class="rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-700"
      >
        搜索
      </button>
    </form>

    {
      query && !errorMessage && (
        <p class="mt-4 text-sm text-slate-500">
          {packs.length > 0 ? `找到 ${packs.length} 个结果` : `未找到与「${query}」相关的公开包`}
          {' · '}
          <a href="/packs" class="text-blue-600 hover:text-blue-700">清除搜索</a>
        </p>
      )
    }

    {
      errorMessage ? (
        <div class="mt-10">
          <EmptyState
            title={isConfigError ? '服务配置不完整' : '无法加载公开包列表'}
            description={
              isConfigError
                ? '站点尚未配置 Supabase 连接。若你是维护者，请配置 PUBLIC_SUPABASE_URL 与 PUBLIC_SUPABASE_ANON_KEY。'
                : errorMessage
            }
          />
        </div>
      ) : packs.length === 0 ? (
        <div class="mt-10">
          <EmptyState
            title={query ? '没有匹配的公开包' : '暂无公开包'}
            description={
              query
                ? '试试更短的关键词，或浏览全部公开包。'
                : '目前还没有已上架的公开包。你可以稍后再来，或先了解 App 与导入文档。'
            }
          />
        </div>
      ) : (
        <ul class="mt-10 grid gap-4 sm:grid-cols-2">
          {
            packs.map((pack) => (
              <li>
                <a
                  href={`/pack/${pack.pack_id}`}
                  class="block rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-blue-200 hover:shadow-md"
                >
                  <h2 class="text-lg font-semibold text-slate-900">{pack.title}</h2>
                  {pack.description && (
                    <p class="mt-2 line-clamp-2 text-sm text-slate-600">{pack.description}</p>
                  )}
                  <div class="mt-4 flex flex-wrap gap-2 text-xs text-slate-500">
                    {pack.author_nickname && <span>{pack.author_nickname}</span>}
                    {pack.question_count != null && <span>{pack.question_count} 题</span>}
                    {pack.version != null && <span>v{pack.version}</span>}
                    {formatDateZh(pack.updated_at) && (
                      <span>{formatDateZh(pack.updated_at)}</span>
                    )}
                  </div>
                  {pack.tags && pack.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-1.5">
                      {pack.tags.slice(0, 4).map((tag) => (
                        <span class="rounded-full bg-blue-50 px-2 py-0.5 text-xs text-blue-700">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      )
    }
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  @reference "../../styles/global.css";

  .sr-only {
    @apply absolute h-px w-px overflow-hidden whitespace-nowrap border-0 p-0;
    clip: rect(0, 0, 0, 0);
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
