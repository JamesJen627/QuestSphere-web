---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const features = [
  'Excel 导入，即刻开练',
  '模考、错题本、收藏与数据大盘',
  '发现公开包，订阅共享题库',
  '学习小组协作编辑与 PK',
];

const ecosystemSteps = [
  'PDF 可搜索化',
  'DeepTutor 部署与定制出题',
  'Excel 导出补丁',
  '题域刷题（练）',
  '公开包订阅',
];
---

<BaseLayout
  title="题域 QuestSphere — 全链路备考里的刷题与共享层"
  description="先体验官方精选题库，再决定是否导入自己的 Excel。题域是 Android 刷题 App，负责全链路备考中的练习与共享。"
>
  <Header slot="header" />

  <section class="mx-auto max-w-5xl px-4 py-16">
    <div class="max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-wide text-blue-600">QuestSphere · 题域</p>
      <h1 class="mt-3 text-balance text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">
        全链路备考里的刷题与共享层
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        先刷官方精选题库，再决定是否导入自己的 Excel。完整刷题与订阅在 Android App 内完成。
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href="/packs"
          class="rounded-lg bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700"
        >
          体验官方精选题库
        </a>
        <a
          href="#ecosystem"
          class="rounded-lg border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-blue-300 hover:text-blue-600"
        >
          了解全链路服务
        </a>
        <a
          href="/download"
          class="px-2 py-3 text-sm font-medium text-slate-500 transition hover:text-blue-600"
        >
          下载 App →
        </a>
      </div>
    </div>
  </section>

  <section id="ecosystem" class="scroll-mt-20 border-y border-slate-200 bg-white">
    <div class="mx-auto max-w-5xl px-4 py-14">
      <h2 class="text-2xl font-bold text-slate-900">全链路备考服务</h2>
      <p class="mt-3 max-w-3xl text-slate-600 leading-7">
        从 PDF 整理到个性化出题，再到刷题沉淀与公开包共享——题域负责其中<strong>「练」</strong>这一环。
        前段 PDF 可搜索化、DeepTutor 部署与定制出题等服务，欢迎联系咨询。
      </p>

      <ol class="mt-8 flex flex-wrap gap-3">
        {
          ecosystemSteps.map((step, index) => (
            <li class="flex items-center gap-3">
              <span
                class:list={[
                  'rounded-full px-3 py-1 text-sm font-medium',
                  index === 3
                    ? 'bg-blue-600 text-white'
                    : 'bg-blue-50 text-blue-700',
                ]}
              >
                {index + 1}. {step}
              </span>
              {index < ecosystemSteps.length - 1 && <span class="text-slate-300">→</span>}
            </li>
          ))
        }
      </ol>

      <p class="mt-8 text-sm text-slate-500">
        前段服务（PDF / DeepTutor / 定制出题）咨询：
        <a href="mailto:jamesjen627@gmail.com" class="font-medium text-blue-600 hover:text-blue-700">
          jamesjen627@gmail.com
        </a>
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-16">
    <h2 class="text-xl font-semibold text-slate-800">核心能力</h2>
    <p class="mt-2 text-sm text-slate-500">已了解题域定位？以下是 App 内主要功能</p>
    <ul class="mt-6 grid gap-4 sm:grid-cols-2">
      {
        features.map((feature) => (
          <li class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">{feature}</li>
        ))
      }
    </ul>
  </section>

  <Footer slot="footer" />
</BaseLayout>
