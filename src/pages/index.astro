---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const features = [
  'Excel 导入，即刻开练',
  '模考、错题本、收藏与数据大盘',
  '发现公开包，订阅共享题库',
  '学习小组协作编辑与 PK',
];

const pipeline = ['PDF 可搜索化', 'DeepTutor 个性化出题', 'Excel 导出', '题域 Android 刷题', 'Supabase 公开包/云同步'];
---

<BaseLayout>
  <Header slot="header" />

  <section class="mx-auto max-w-5xl px-4 py-16">
    <div class="max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-wide text-blue-600">QuestSphere</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        题域 — 导入即练，发现共享题库
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        一条龙生态中的「练习与沉淀层」：Excel/DeepTutor 出题 → 题域导入刷题 → 可选发布到发现题库供他人订阅。
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/download"
          class="rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700"
        >
          下载 Android App
        </a>
        <a
          href="/docs"
          class="rounded-lg border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-blue-300 hover:text-blue-600"
        >
          查看导入文档
        </a>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-white">
    <div class="mx-auto max-w-5xl px-4 py-12">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">一条龙链路</h2>
      <ol class="mt-6 flex flex-wrap gap-3">
        {
          pipeline.map((step, index) => (
            <li class="flex items-center gap-3">
              <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-700">
                {index + 1}. {step}
              </span>
              {index < pipeline.length - 1 && <span class="text-slate-300">→</span>}
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-16">
    <h2 class="text-2xl font-bold text-slate-900">核心能力</h2>
    <ul class="mt-8 grid gap-4 sm:grid-cols-2">
      {
        features.map((feature) => (
          <li class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">{feature}</li>
        ))
      }
    </ul>
  </section>

  <Footer slot="footer" />
</BaseLayout>
