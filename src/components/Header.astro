---
const nav = [
  { href: '/', label: '首页' },
  { href: '/packs', label: '精选题库' },
  { href: '/docs', label: '文档' },
  { href: '/download', label: '下载' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
    <a href="/" class="text-lg font-semibold text-blue-600">题域 QuestSphere</a>

    <nav class="hidden items-center gap-6 text-sm font-medium md:flex" aria-label="主导航">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'transition',
              isActive(item.href)
                ? 'text-blue-600'
                : 'text-slate-600 hover:text-blue-600',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <details class="relative md:hidden">
      <summary
        class="cursor-pointer list-none rounded-lg border border-slate-200 px-3 py-2 text-sm font-medium text-slate-700 [&::-webkit-details-marker]:hidden"
        aria-label="打开菜单"
      >
        菜单
      </summary>
      <nav
        class="absolute right-0 mt-2 w-40 rounded-xl border border-slate-200 bg-white p-2 shadow-lg"
        aria-label="移动端导航"
      >
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'block rounded-lg px-3 py-2 text-sm transition',
                isActive(item.href)
                  ? 'bg-blue-50 font-medium text-blue-600'
                  : 'text-slate-700 hover:bg-slate-50',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>

<style>
  details[open] summary {
    border-color: rgb(147 197 253);
    color: rgb(37 99 235);
  }
</style>
