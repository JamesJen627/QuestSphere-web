---
interface Props {
  title: string;
  description: string;
  packId?: string;
}

const { title, description, packId } = Astro.props;
---

<div class="rounded-xl border border-slate-200 bg-white p-8">
  <p class="text-sm font-medium text-slate-500">{title}</p>
  <p class="mt-2 text-lg text-slate-700">{description}</p>
  {packId && (
    <p class="mt-3 font-mono text-xs text-slate-400">packId: {packId}</p>
  )}
  <div class="mt-8 flex flex-wrap gap-3">
    <a
      href="/"
      class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700"
    >
      返回首页
    </a>
    <a
      href="/packs"
      class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-blue-300 hover:text-blue-600"
    >
      浏览公开包
    </a>
    <a
      href="/download"
      class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-blue-300 hover:text-blue-600"
    >
      了解 App
    </a>
  </div>
</div>
