---
import { stripMarkdownForPreview } from '../lib/preview';
import {
  getOptionMarker,
  getQuestionKind,
  getQuestionTypeLabel,
  parseOptions,
} from '../lib/question-preview';
import type { PublicPackQuestion } from '../types/public-pack';

interface Props {
  question: PublicPackQuestion;
  index: number;
}

const { question, index } = Astro.props;

const kind = getQuestionKind(question.type);
const options = parseOptions(question.optionsJson);
const stem = stripMarkdownForPreview(question.question);
const explanation = question.explanation ? stripMarkdownForPreview(question.explanation) : '';
---

<article class="rounded-xl border border-slate-200 bg-white p-5">
  <div class="flex flex-wrap items-center gap-2">
    <p class="text-xs font-medium uppercase text-slate-400">第 {index + 1} 题</p>
    <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">
      {getQuestionTypeLabel(question.type)}
    </span>
  </div>

  {stem && <p class="mt-3 whitespace-pre-wrap text-slate-800">{stem}</p>}

  {
    options.length > 0 && (
      <ul class="mt-4 space-y-2" aria-label="选项（只读预览，不公布答案）">
        {
          options.map((option, optionIndex) => (
            <li class="flex gap-3 rounded-lg border border-slate-100 bg-slate-50 px-3 py-2 text-sm text-slate-700">
              <span class="font-semibold text-slate-500">{getOptionMarker(optionIndex, kind)}.</span>
              <span>{stripMarkdownForPreview(option)}</span>
            </li>
          ))
        }
      </ul>
    )
  }

  {
    explanation && (
      <div class="mt-4 rounded-lg border border-emerald-100 bg-emerald-50 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">解析</p>
        <p class="mt-2 whitespace-pre-wrap text-sm leading-6 text-emerald-900">{explanation}</p>
      </div>
    )
  }
</article>
